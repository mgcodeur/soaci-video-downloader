    "lint-staged": "^15.4.3",
    "@types/chrome": "^0.0.287",
    "@vitejs/plugin-vue": "^5.2.3",
    "prettier": "^3.5.3",
    "typescript": "^5.7.3",
    "vite": "^6.3.2",
    "vite-plugin-web-extension": "^4.3.1",
    "vitest": "^3.1.1",
    "jsdom": "^26.0.0",
    "vue": "^3.5.13"
  }
}
